name: Actualizar IPTV Argentina

on:
  schedule:
    - cron: '0 */6 * * *'   # cada 6 horas
  workflow_dispatch:

jobs:
  update:
    runs-on: ubuntu-latest

    steps:
      - name: Descargar repo
        uses: actions/checkout@v3

      - name: Descargar listas oficiales
        run: |
          echo "#EXTM3U" > lista.m3u
          echo "" >> lista.m3u
          
          echo "# Telefe " >> lista.m3u
          curl -L http://dplatino.net/live/Copla/HH28wHfJ5hSV/81285.m3u8 >> lista.m3u
          
          echo "" >> lista.m3u
          echo "# Deportes abiertos" >> lista.m3u
          curl -L https://iptv-org.github.io/iptv/categories/sports.m3u >> lista.m3u

      - name: Guardar cambios
        run: |
          git config --global user.name "iptv-auto"
          git config --global user.email "auto@github.com"
          git add lista.m3u
          git commit -m "Actualización automática" || echo "Sin cambios"
          git push
